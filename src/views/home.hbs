<!-- Banner Estático -->
<div class="mb-5">
  <img src="/uploads/banner.png" class="d-block w-100" alt="Banner Principal" style="object-fit: cover; height: 500px;">
</div>

<div class="container mt-5">
  <h1 class="mb-4">Bienvenido a nuestra tienda</h1>

  {{#if recomendaciones}}
    <h2 class="mb-3">Recomendados para ti</h2>
    <div class="row">
      {{#each recomendaciones}}
        <div class="col-sm-6 col-md-4 col-lg-3 mb-4">
          <div class="card h-100 shadow-sm">
            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height:200px;">
              {{#if this.imagen}}
                <img src="/uploads/{{this.imagen}}" alt="{{this.nombre}}" class="img-fluid" style="max-height:100%; object-fit:contain;">
              {{else}}
                <i class="fas fa-shoe-prints fa-3x text-muted"></i>
              {{/if}}
            </div>
            <div class="card-body d-flex flex-column">
              <h5 class="card-title text-truncate">{{this.nombre}}</h5>
              {{#if this.categoria}}
                <p class="mb-2"><small class="badge bg-secondary">{{this.categoria.nombre}}</small></p>
              {{/if}}
              <p class="h6 text-primary mb-2">${{this.precio}}</p>
              <a href="/catalogo/detalle/{{this.id_producto}}" class="btn btn-outline-primary btn-sm mt-auto">Ver detalle</a>
            </div>
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    <p>No hay recomendaciones disponibles.</p>
  {{/if}}
</div>
<!-- Galería de Imágenes -->
<div class="mt-5 mb-5">
  <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0; margin: 0; width: 100%;">
    <img src="/uploads/1.png" alt="Modelo 1" style="width: 100%; height: auto; object-fit: contain; display: block;">
    <img src="/uploads/2.png" alt="Modelo 2" style="width: 100%; height: auto; object-fit: contain; display: block;">
    <img src="/uploads/3.png" alt="Modelo 3" style="width: 100%; height: auto; object-fit: contain; display: block;">
    <img src="/uploads/4.png" alt="Modelo 4" style="width: 100%; height: auto; object-fit: contain; display: block;">
  </div>
</div>
</div>
<div class="container mt-4">
  <h3>Inventario de: {{producto.nombre}}</h3>

  <a href="/admin/dashboard/productos" class="btn btn-secondary mb-3">Volver a productos</a>
  <a href="/admin/dashboard/productos/{{producto.id_producto}}/inventario/registrar" class="btn btn-primary mb-3">Agregar talle</a>

  {{#if talles.length}}
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Talle</th>
          <th>Stock</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        {{#each talles}}
          <tr>
            <td>{{this.id_inventario}}</td>
            <td>{{this.talle}}</td>
            <td>{{this.stock}}</td>
            <td>
              <a href="/admin/dashboard/productos/inventario/{{this.id_inventario}}/editar" class="btn btn-sm btn-warning">Editar</a>
              <form action="/admin/dashboard/productos/inventario/{{this.id_inventario}}/eliminar" method="POST" style="display:inline" onsubmit="return confirm('Eliminar registro?')">
                <button class="btn btn-sm btn-danger">Eliminar</button>
              </form>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <div class="alert alert-info">No hay talles registrados para este producto.</div>
  {{/if}}
</div>
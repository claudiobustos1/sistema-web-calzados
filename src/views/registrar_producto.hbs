
<div class="container mt-4">
  {{#if varMensaje}}
    <div class="alert alert-{{varEstiloMensaje}}">{{varMensaje}}</div>
  {{/if}}

  <h1>Registrar producto</h1>

  <form action="/admin/dashboard/productos/registrar" method="POST" enctype="multipart/form-data" class="mt-3">
    <div class="mb-3">
      <label for="nombre" class="form-label">Nombre</label>
      <input id="nombre" name="nombre" class="form-control" required>
    </div>

    <div class="mb-3">
      <label for="descripcion" class="form-label">Descripción</label>
      <textarea id="descripcion" name="descripcion" class="form-control" rows="3"></textarea>
    </div>

    <div class="row">
      <div class="col-md-4 mb-3">
        <label for="precio" class="form-label">Precio</label>
        <input id="precio" name="precio" type="number" step="0.01" class="form-control" required>
      </div>

      <div class="col-md-4 mb-3">
        <label for="stock_minimo" class="form-label">Stock mínimo</label>
        <input id="stock_minimo" name="stock_minimo" type="number" class="form-control">
      </div>

      <div class="col-md-4 mb-3">
        <label for="imagen" class="form-label">Imagen</label>
        <input id="imagen" name="imagen" type="file" accept=".jpg,.png" class="form-control">
      </div>
    </div>

    <div class="row">
      <div class="col-md-6 mb-3">
        <label for="id_categoria" class="form-label">Categoría</label>
        <select id="id_categoria" name="id_categoria" class="form-select" required>
          <option value="">-- Seleccionar categoría --</option>
          {{#each categorias}}
            <option value="{{this.id_categoria}}">{{this.nombre}}</option>
          {{/each}}
        </select>
      </div>

      <div class="col-md-6 mb-3">
        <label for="id_proveedor" class="form-label">Proveedor</label>
        <select id="id_proveedor" name="id_proveedor" class="form-select" required>
          <option value="">-- Seleccionar proveedor --</option>
          {{#each proveedores}}
            <option value="{{this.id_proveedor}}">{{this.empresa}}</option>
          {{/each}}
        </select>
      </div>
    </div>

    <hr>

    <h5>Inventario</h5>
    <div class="row">
      <div class="col-md-6 mb-3">
        <label for="stock" class="form-label">Stock inicial</label>
        <input id="stock" name="stock" type="number" min="0" class="form-control" required>
      </div>

      <div class="col-md-6 mb-3">
        <label for="talle" class="form-label">Talle</label>
        <input id="talle" name="talle" class="form-control">
      </div>
    </div>

    <div class="d-flex gap-2">
      <a href="/admin/dashboard/productos" class="btn btn-secondary">Cancelar</a>
      <button type="submit" class="btn btn-primary">Registrar producto</button>
    </div>
  </form>
</div>

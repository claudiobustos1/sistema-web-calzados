<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calzados Store - {{title}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/form-registro.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Pirata+One&display=swap');
        .bg-violeta-azulado {
            background-color: #6a5acd !important; 
        }
        
        .bg-violeta-azulado-claro {
            background-color: #7b68ee !important; 
        }
        
        .btn-violeta-azulado {
            background-color: #6a5acd;
            border-color: #6a5acd;
            color: white;
        }
        
        .btn-violeta-azulado:hover {
            background-color: #5a4abc;
            border-color: #5a4abc;
            color: white;
        }
        
        .btn-outline-violeta-azulado {
            border-color: #6a5acd;
            color: #6a5acd;
        }
        
        .btn-outline-violeta-azulado:hover {
            background-color: #6a5acd;
            color: white;
        }
        
        .text-violeta-azulado {
            color: #6a5acd !important;
        }
        
        /* Estilos generales */
        body {
            padding-top: 76px; /* Para compensar el navbar fixed */
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        
        main {
            flex: 1;
        }
        
        footer {
            margin-top: auto;
        }
        
        /* Navbar corregido */
        .navbar-brand {
            background-color: transparent !important;
        }
        
        .navbar-brand img {
            background-color: transparent;
            border: none;
        }
        .navbar-brand {
            font-family: "Pirata One", system-ui;
        }
        
        /* Mejoras visuales */
        .dropdown-menu {
            border: none;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        
        .dropdown-item:hover {
            background-color: #6a5acd;
            color: white;
        }
    </style>
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-violeta-azulado fixed-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/img/logo.png" alt="Logo" width="30" height="24" class="d-inline-block align-text-top me-2">
                Calzados Store
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                data-bs-target="#navbarSupportedContent">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link {{#if active.home}}active{{/if}}" href="/">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{#if active.catalogo}}active{{/if}}" href="/catalogo">Catálogo</a>
                    </li>
                </ul>
                
                <div class="d-flex align-items-center">
                    <!-- Buscador -->
                    <form class="d-flex me-2" action="/buscar" method="GET">
                        <input class="form-control me-2" type="search" name="q" placeholder="Buscar calzado...">
                        <button class="btn btn-outline-light" type="submit">
                            <i class="fas fa-search"></i>
                        </button>
                    </form>
                    
                    <!-- Carrito y Usuario -->
                    <ul class="navbar-nav mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#carritoModal">
                                <i class="fas fa-shopping-bag"></i> Carrito
                                {{#if cartCount}}
                                <span class="badge bg-warning text-dark">{{cartCount}}</span>
                                {{/if}}
                            </a>
                        </li>
                        <li class="nav-item">
                            {{#if user}}
                            <div class="dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user"></i> {{user.nombre}}
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="/perfil">Mi Perfil</a></li>
                                    <li><a class="dropdown-item" href="/pedidos">Mis Pedidos</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="/logout">Cerrar Sesión</a></li>
                                </ul>
                            </div>
                            {{else}}
                            <a class="nav-link {{#if active.login}}active{{/if}}" href="/inicioSesion">
                                <i class="fas fa-user"></i> Iniciar Sesión
                            </a>
                            {{/if}}
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <!-- Contenido principal -->
    <main class="container-fluid py-4">
        {{{body}}}
    </main>

    <!-- Footer-->
    <footer class="bg-violeta-azulado text-white py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    <h5>Calzados Store</h5>
                    <p>Tu tienda de confianza para encontrar el calzado perfecto.</p>
                </div>
                <div class="col-md-4">
                    <h5>Enlaces rápidos</h5>
                    <ul class="list-unstyled">
                        <li><a href="/" class="text-white">Inicio</a></li>
                        <li><a href="/catalogo" class="text-white">Catálogo</a></li>
                        <li><a href="/contacto" class="text-white">Contacto</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h5>Contacto</h5>
                    <address>
                        <i class="fas fa-map-marker-alt"></i> Dirección: Calle Falsa 123<br>
                        <i class="fas fa-phone"></i> Teléfono: +55 55555555<br>
                        <i class="fas fa-envelope"></i> Email: info@calzadosstore.com
                    </address>
                </div>
            </div>
            <hr class="my-4">
            <div class="text-center">
                <p>&copy; 2025 Calzados Store. Todos los derechos reservados.</p>
            </div>
        </div>
    </footer>

    <!-- Modal del Carrito -->
    <div class="modal fade" id="carritoModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-violeta-azulado text-white">
                    <h5 class="modal-title">Mi Carrito</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="carritoContenido">
                    <!-- El contenido del carrito se cargará aquí -->
                    <p>Cargando carrito...</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                    <a href="/carrito" class="btn btn-violeta-azulado">Ver carrito completo</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS y dependencias -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('carritoModal').addEventListener('show.bs.modal', function () {
            fetch('/api/carrito')
                .then(res => res.text())
                .then(html => document.getElementById('carritoContenido').innerHTML = html)
                .catch(err => document.getElementById('carritoContenido').innerHTML = 'Error al cargar el carrito');
        });
    </script>
</body>

</html>
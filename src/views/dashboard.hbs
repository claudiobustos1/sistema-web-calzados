<!-- Header -->
<div class="header d-flex justify-content-between align-items-center">
    <h4 class="mb-0">Dashboard</h4>
</div>

<!-- Metrics Cards -->
<div class="row mb-3">
    <div class="col-md-4 col-6">
        <div class="card metric-card">
            <div class="card-body py-2">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="metric-value">$0</div>
                        <div class="metric-title">Ingresos Totales</div>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-currency-dollar" style="font-size: 24px;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-6">
        <div class="card metric-card">
            <div class="card-body py-2">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="metric-value">0</div>
                        <div class="metric-title">Usuarios Registrados</div>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-people" style="font-size: 24px;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-12 mt-md-0 mt-2">
        <div class="card metric-card">
            <div class="card-body py-2">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="metric-value">0</div>
                        <div class="metric-title">Pedidos</div>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-cart" style="font-size: 24px;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts and Tables -->
<div class="row mb-3">
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header">
                Productos Populares
            </div>
            <div class="card-body p-0">
                <div class="table-container">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th>Precio</th>
                                <th>Ventas</th>
                                <th>Inventario</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        
                    </table>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4 mt-lg-0 mt-3">
        <div class="card h-100">
            <div class="card-header">
                Actividad Reciente
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                   
                </ul>
            </div>
        </div>
    </div>
</div>